{
  "name": "voice-agent",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "test": "vitest --run",
    "test:watch": "vitest",
    "dev": "pnpm run build && node dist/main.js dev",
    "download-files": "pnpm run build && node dist/main.js download-files",
    "start": "node dist/main.js start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@livekit/agents": "^1.4.1",
    "@livekit/agents-plugin-livekit": "^1.4.1",
    "@livekit/agents-plugin-silero": "^1.4.1",
    "@livekit/plugins-ai-coustics": "^0.2.12",
    "dotenv": "^17.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
